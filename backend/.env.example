# Codebase City Backend — Environment Variables
# Copy this file to .env and fill in the values

# Required: Gemini AI API Key (for AI Architect feature)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub OAuth (for private repository analysis)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: JWT Secret for session management (auto-generated if not set)
JWT_SECRET=change_me_to_a_random_string

# Optional: Server Configuration
HOST=0.0.0.0
PORT=8000
