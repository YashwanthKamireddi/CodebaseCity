# Codebase City Frontend — Environment Variables
# Copy this file to .env and fill in the values

# API URL — defaults to /api (proxied by Vite in dev)
# For production, set to your backend URL, e.g. https://codebase-city-api.onrender.com
VITE_API_URL=/api

# GitHub OAuth (for user authentication)
# 1. Create an OAuth App at https://github.com/settings/developers
# 2. Set the "Authorization callback URL" to match VITE_GITHUB_REDIRECT_URI below
#    (for local dev: http://localhost:5173/  ·  for prod: https://your-domain.com/)
# 3. GitHub OAuth Apps only accept ONE callback URL — register a separate dev app
#    if you need both local + prod, and swap .env values when switching.
VITE_GITHUB_CLIENT_ID=your_client_id

# Optional — overrides the callback URL the client sends to GitHub.
# Defaults to window.location.origin + "/". Only set this when you want the
# client to send a redirect_uri different from the current origin (rare).
# VITE_GITHUB_REDIRECT_URI=http://localhost:5173/

# Server-side only (for Vercel serverless function)
# DO NOT prefix with VITE_ — this keeps it secret
GITHUB_CLIENT_SECRET=your_client_secret
