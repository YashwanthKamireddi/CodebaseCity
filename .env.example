# Codebase City Frontend — Environment Variables
# Copy this file to .env and fill in the values

# API URL — defaults to /api (proxied by Vite in dev)
# For production, set to your backend URL, e.g. https://codebase-city-api.onrender.com
VITE_API_URL=/api

# GitHub OAuth (for user authentication)
# Create an OAuth App at https://github.com/settings/developers
VITE_GITHUB_CLIENT_ID=your_client_id

# Server-side only (for Vercel serverless function)
# DO NOT prefix with VITE_ — this keeps it secret
GITHUB_CLIENT_SECRET=your_client_secret
